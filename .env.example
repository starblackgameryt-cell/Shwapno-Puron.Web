# ============================================
# স্বপ্ন পূরণ — Environment Variables
# ============================================
# Copy this file to .env (local dev) or set these in Vercel dashboard.

# ---------- DATABASE ----------
# Option A: Local SQLite (development only)
DATABASE_URL=file:./dev.db

# Option B: Turso Cloud (REQUIRED for Vercel/Netlify deployment)
# Create free DB at https://turso.tech
# DATABASE_URL=libsql://your-db-name-your-org.turso.co
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# ---------- AUTH ----------
# Generate a random 32+ char string: https://generate-secret.vercel.app/
NEXTAUTH_SECRET=your-secret-key-here-change-this
# In production, set this to your Vercel URL (e.g. https://your-app.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# ---------- ADMIN CREDENTIALS ----------
# Used to log into /admin dashboard
ADMIN_EMAIL=your-admin@email.com
ADMIN_PASSWORD=your-admin-password

# ---------- GOOGLE OAUTH (Optional) ----------
# Only needed if you want Google login. See DEPLOY-GUIDE.md Step 3.
# Get these from https://console.cloud.google.com (OAuth consent screen)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- OPTIONAL ----------
# Public site URL — used for SEO (sitemap, Open Graph, canonical URLs).
# In production, set this to your Vercel domain. Falls back to NEXTAUTH_URL.
SITE_URL=https://shwapno-puron-web.vercel.app

# Override the business WhatsApp number (defaults to +880 1913551490)
# BUSINESS_PHONE=8801913551490
